NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# E17 — ИИ-ассистент подростка. Личный некоммерческий ключ: без него агент
# полностью скрыт. Доступ дополнительно гасится рантайм-флагом app_settings.ai_agent_enabled
# (по умолчанию выключен) и дневным лимитом сообщений на подростка.
OPENAI_API_KEY=
OPENAI_AGENT_MODEL=gpt-4o-mini
AI_AGENT_DAILY_LIMIT=30
